# ============================================================
# TradeFeed — Environment Variables
# ============================================================
# NEVER commit this file. It's in .gitignore.
# Copy to .env and fill in real values.
# ============================================================

# Database — PostgreSQL (Supabase, Neon, or local)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://user:password@localhost:5432/tradefeed

# Clerk Authentication (Phase 3)
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
# CLERK_SECRET_KEY=""
# CLERK_WEBHOOK_SECRET=""

# Image Upload — Uploadthing CDN (Phase 4)
# Get your token from https://uploadthing.com/dashboard
# UPLOADTHING_TOKEN=""

# PayFast — SA Payment Gateway (Phase 5)
# Get credentials from https://www.payfast.co.za/registration
# PAYFAST_MERCHANT_ID=""
# PAYFAST_MERCHANT_KEY=""
# PAYFAST_PASSPHRASE=""

# Resend — Email Notifications (Phase 10+)
# Get your API key from https://resend.com/api-keys
# RESEND_API_KEY=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Platform Admin — Comma-separated Clerk user IDs for admin access
# ADMIN_USER_IDS="user_abc123,user_def456"

# Feature Flags — all default OFF (see lib/config/feature-flags.ts)
# NEXT_PUBLIC_FF_WHATSAPP_PRODUCT_IMPORT="true"
# Buyer retention (Phase 1)
# NEXT_PUBLIC_FF_BUYER_ACCOUNTS="true"
# NEXT_PUBLIC_FF_SHOP_FOLLOW="true"
# Trust system (Phase 2)
# NEXT_PUBLIC_FF_TRUST_SYSTEM="true"
# NEXT_PUBLIC_FF_REVIEW_REQUESTS="true"
# AI deepening (Phase 3)
# NEXT_PUBLIC_FF_LISTING_TRANSLATIONS="true"
# NEXT_PUBLIC_FF_PRICE_SUGGESTIONS="true"
# NEXT_PUBLIC_FF_BG_REMOVAL="true"
# Onboarding (Phase 4)
# NEXT_PUBLIC_FF_WA_IMPORT_PRIMARY="true"
# NEXT_PUBLIC_FF_CATALOGUE_IMPORT="true"

# Background Removal (Phase 3) — remove.bg API key
# Get one at https://www.remove.bg/api — graceful no-op when unset
# BG_REMOVAL_API_KEY=""
